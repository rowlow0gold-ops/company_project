---
import type { Lang } from "../lib/i18n";
interface Props { lang?: Lang; }
const { lang = "ko" } = Astro.props;
const label = lang === "en" ? "Loading" : "로딩 중";
---

<div id="intro-loader" class="intro-loader" aria-hidden="true">
  <div class="intro-inner">
    <div class="intro-mark">NEXORA</div>
    <div class="intro-meta">
      <span class="intro-label">{label}</span>
      <span class="intro-pct" id="intro-pct">0%</span>
    </div>
    <div class="intro-bar"><span class="intro-bar-fill"></span></div>
  </div>
</div>

<style>
  .intro-loader {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: var(--color-ink);
    color: var(--color-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.6s ease, transform 0.7s cubic-bezier(0.65, 0, 0.35, 1);
  }
  .intro-loader.is-leaving {
    opacity: 0;
    transform: translateY(-100%);
    pointer-events: none;
  }
  .intro-loader.is-removed { display: none; }

  .intro-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
    min-width: 260px;
  }
  .intro-mark {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 600;
    letter-spacing: var(--tracking-tighter);
  }
  .intro-meta {
    display: flex;
    justify-content: space-between;
    width: 100%;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-fg-mute);
  }
  .intro-pct { color: var(--color-fg); }
  .intro-bar {
    width: 100%;
    height: 1px;
    background: var(--color-line-strong);
    overflow: hidden;
  }
  .intro-bar-fill {
    display: block;
    height: 100%;
    width: 0%;
    background: var(--color-fg);
    transition: width 1.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .intro-loader.is-running .intro-bar-fill { width: 100%; }
</style>

<script is:inline>
  (() => {
    const loader = document.getElementById("intro-loader");
    if (!loader) return;

    // Skip on subsequent navigations within the same session.
    let seen = false;
    try { seen = sessionStorage.getItem("nexora-intro") === "seen"; } catch {}
    if (seen) {
      loader.classList.add("is-removed");
      return;
    }

    const pct = document.getElementById("intro-pct");
    const total = 1500; // total counter run time (ms)
    const start = performance.now();

    // Trigger the CSS width transition next frame.
    requestAnimationFrame(() => loader.classList.add("is-running"));

    const tick = (now) => {
      const p = Math.min(1, (now - start) / total);
      const v = Math.floor(p * 100);
      if (pct) pct.textContent = v + "%";
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);

    setTimeout(() => {
      loader.classList.add("is-leaving");
      try { sessionStorage.setItem("nexora-intro", "seen"); } catch {}
      setTimeout(() => loader.classList.add("is-removed"), 750);
    }, total + 150);
  })();
</script>
