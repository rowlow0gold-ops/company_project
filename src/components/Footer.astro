---
import { t, localizePath, getSite, type Lang } from "../lib/i18n";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const site = getSite(lang);

const columns = [
  {
    title: t(lang, "footer_company"),
    links: [
      { label: t(lang, "footer_about"),    href: "/about" },
      { label: t(lang, "footer_services"), href: "/services" },
      { label: t(lang, "footer_news"),     href: "/news" },
      { label: t(lang, "footer_careers"),  href: "/careers" },
    ],
  },
  {
    title: t(lang, "footer_contact"),
    links: [
      { label: t(lang, "footer_inquiry"), href: "/contact" },
      { label: site.email, href: `mailto:${site.email}` },
      { label: site.phone, href: `tel:${site.phone.replace(/[^0-9+]/g, "")}` },
    ],
  },
  {
    title: t(lang, "footer_policy"),
    links: [
      { label: t(lang, "footer_terms"),         href: "#",  popup: "terms"   as const },
      { label: t(lang, "footer_privacy"),       href: "#",  popup: "privacy" as const },
      { label: t(lang, "footer_email_policy"),  href: "#",  popup: "email"   as const },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-ink-soft)] border-t border-line mt-32">
  <div class="container-x py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
      <div class="lg:col-span-5">
        <a href={localizePath("/", lang)} class="text-3xl font-semibold tracking-[var(--tracking-tight)]">
          NEXORA
        </a>
        <p class="mt-6 text-fg-mute max-w-md leading-relaxed">{site.description}</p>

        <div class="mt-10 flex items-center gap-3">
          {site.social.linkedin && (
            <a
              href={site.social.linkedin}
              target="_blank"
              rel="noreferrer"
              class="w-10 h-10 grid place-items-center rounded-full border border-line hover:border-line-strong hover:text-fg text-fg-mute transition-colors"
              aria-label="LinkedIn"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3V9zm7 0h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.65 4.78 6.1V21H18.6v-5.5c0-1.32-.02-3.02-1.85-3.02-1.85 0-2.13 1.44-2.13 2.93V21H10V9z"/></svg>
            </a>
          )}
          {site.social.github && (
            <a
              href={site.social.github}
              target="_blank"
              rel="noreferrer"
              class="w-10 h-10 grid place-items-center rounded-full border border-line hover:border-line-strong hover:text-fg text-fg-mute transition-colors"
              aria-label="GitHub"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5a11.5 11.5 0 0 0-3.64 22.42c.58.1.79-.25.79-.56v-2.04c-3.2.7-3.87-1.37-3.87-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.74-1.56-2.55-.3-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.3-.51-1.48.11-3.08 0 0 .96-.31 3.15 1.18a10.95 10.95 0 0 1 5.74 0c2.19-1.5 3.15-1.18 3.15-1.18.62 1.6.23 2.78.11 3.08.73.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.4-5.26 5.69.41.36.78 1.05.78 2.12v3.14c0 .31.21.67.8.55A11.5 11.5 0 0 0 12 .5z"/></svg>
            </a>
          )}
        </div>
      </div>

      <div class="lg:col-span-7 grid grid-cols-2 sm:grid-cols-3 gap-8">
        {columns.map((col) => (
          <div>
            <h4 class="text-[11px] uppercase tracking-[0.2em] text-fg-mute mb-5">{col.title}</h4>
            <ul class="space-y-3">
              {col.links.map((l) => (
                <li>
                  <a
                    href={l.href.startsWith("/") ? localizePath(l.href, lang) : l.href}
                    data-popup-open={"popup" in l ? l.popup : undefined}
                    class="text-sm text-fg-soft hover:text-fg transition-colors"
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-line grid grid-cols-1 lg:grid-cols-12 gap-6 text-xs text-fg-mute">
      <div class="lg:col-span-6 space-y-1.5">
        <div>{t(lang, "footer_ceo")} <span class="text-fg-soft">{site.ceo}</span> &nbsp; · &nbsp; {t(lang, "footer_biz_reg")} <span class="text-fg-soft">{site.biz_reg}</span></div>
        <div>{t(lang, "footer_hq")} · {site.address_hq}</div>
        <div>{t(lang, "footer_branch")} · {site.address_branch}</div>
      </div>
      <div class="lg:col-span-6 lg:text-right">
        © {year} NEXORA Systems Inc. {t(lang, "footer_rights")}
      </div>
    </div>
  </div>
</footer>
