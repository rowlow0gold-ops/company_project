---
import legalKo from "../data/legal.json";
import legalEn from "../data/en/legal.json";
import type { Lang } from "../lib/i18n";

interface Props {
  name: "terms" | "privacy" | "email";
  lang?: Lang;
}
const { name, lang = "ko" } = Astro.props;
const legal = lang === "en" ? legalEn : legalKo;
const data = legal[name];
const isEn = lang === "en";
const closeLabel = isEn ? "Close" : "닫기";
---

<div
  data-popup={name}
  class="fixed inset-0 z-[70] hidden items-center justify-center bg-black/60 backdrop-blur-sm p-3 md:p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${name}-popup-title`}
>
  <div class="relative max-w-2xl w-full bg-ink rounded-2xl shadow-2xl overflow-hidden flex flex-col max-h-[88vh] border border-line">
    <button
      type="button"
      data-popup-close
      aria-label={closeLabel}
      class="absolute top-3 right-3 z-10 w-9 h-9 rounded-full bg-ink-soft text-fg-soft hover:text-fg hover:bg-ink flex items-center justify-center text-xl border border-line"
    >
      ×
    </button>

    <div class="bg-ink-soft border-b border-line px-6 md:px-8 py-5 md:py-6 shrink-0">
      <p
        id={`${name}-popup-title`}
        role="heading"
        aria-level="2"
        class="text-xl md:text-2xl font-semibold leading-tight tracking-[var(--tracking-tight)]"
      >
        {data.title}
      </p>
      {data.subtitle && <p class="mt-1.5 text-sm text-fg-70">{data.subtitle}</p>}
      {data.updated  && <p class="mt-1 text-[11px] text-fg-mute">{data.updated}</p>}
    </div>

    <div class="flex-1 overflow-y-auto px-6 md:px-8 py-6 space-y-5">
      {data.sections.map((s) => (
        <section>
          <p role="heading" aria-level="3" class="text-sm md:text-base font-semibold text-fg">{s.heading}</p>
          <p class="mt-2 text-sm leading-relaxed text-fg-soft whitespace-pre-line">{s.body}</p>
        </section>
      ))}
    </div>

    <div class="flex border-t border-line shrink-0">
      <button
        type="button"
        data-popup-close
        class="flex-1 py-3.5 text-sm font-medium text-accent hover:bg-ink-soft transition-colors"
      >
        {closeLabel}
      </button>
    </div>
  </div>
</div>
