---
import Layout from "../../layouts/Layout.astro";
import { getLang, getCareers } from "../../lib/i18n";

const lang = getLang(Astro.url);
const data = getCareers(lang);
---

<Layout title={data.eyebrow} lang={lang}>
  <section class="pt-40 pb-20 lg:pt-52 lg:pb-28 border-b border-line">
    <div class="container-x">
      <div class="text-[11px] uppercase tracking-[0.28em] text-accent mb-6">{data.eyebrow}</div>
      <h1 class="text-[clamp(2.5rem,6vw,5.5rem)] font-semibold leading-[1.05] tracking-[var(--tracking-tighter)] max-w-4xl reveal">
        {data.hero_title}
      </h1>
      <p class="mt-10 max-w-2xl text-lg text-fg-70 leading-relaxed reveal" style="transition-delay:120ms">
        {data.hero_body}
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="container-x">
      <div class="divide-y divide-[var(--color-line)] border-y border-line" data-reveal-children>
        {data.positions.map((p) => (
          <a href="#" class="group flex flex-col lg:flex-row lg:items-center justify-between gap-4 lg:gap-8 py-8 lg:py-10 hover:bg-ink-soft px-6 -mx-6 transition-colors">
            <div class="flex-1">
              <div class="text-[11px] uppercase tracking-[0.22em] text-fg-mute mb-2">{p.team}</div>
              <div class="text-2xl lg:text-3xl font-semibold tracking-[var(--tracking-tight)]">{p.role}</div>
            </div>
            <div class="flex items-center gap-6">
              <span class="text-sm text-fg-65">{p.location}</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="text-fg-faint group-hover:text-accent group-hover:translate-x-1 transition-all"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
