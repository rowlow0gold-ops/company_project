---
import Layout from "../layouts/Layout.astro";
import { getLang, getCareers } from "../lib/i18n";

const lang = getLang(Astro.url);
const data = getCareers(lang);
---

<Layout title={data.eyebrow} lang={lang}>
  <section class="pt-40 pb-20 lg:pt-52 lg:pb-28 border-b border-line">
    <div class="container-x grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <div class="lg:col-span-6">
        <div class="text-[11px] uppercase tracking-[0.28em] text-accent mb-6">{data.eyebrow}</div>
        <h1 class="text-[clamp(2.5rem,5vw,4.5rem)] font-semibold leading-[1.05] tracking-[var(--tracking-tighter)] reveal">
          {data.hero_title}
        </h1>
        <p class="mt-8 text-lg text-fg-70 leading-relaxed reveal" style="transition-delay:120ms">
          {data.hero_body}
        </p>

        <a
          href={data.all_openings_url}
          target="_blank"
          rel="noreferrer"
          class="mt-8 inline-flex items-center gap-2 px-6 py-3 rounded-full btn-primary text-sm font-medium reveal"
          style="transition-delay:240ms"
        >
          {data.all_openings_label}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="lg:col-span-6 reveal" style="transition-delay:200ms">
        <div class="aspect-[5/4] overflow-hidden rounded-2xl border border-line">
          <img src="https://images.pexels.com/photos/3183150/pexels-photo-3183150.jpeg?auto=compress&cs=tinysrgb&w=1400" alt={data.eyebrow} class="w-full h-full object-cover" loading="eager" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="container-x">
      <div class="divide-y divide-[var(--color-line)] border-y border-line" data-reveal-children>
        {data.positions.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noreferrer"
            class="group flex flex-col lg:flex-row lg:items-center justify-between gap-4 lg:gap-8 py-8 lg:py-10 hover:bg-ink-soft px-6 -mx-6 transition-colors"
          >
            <div class="flex-1">
              <div class="text-[11px] uppercase tracking-[0.22em] text-fg-mute mb-2">{p.team}</div>
              <div class="text-2xl lg:text-3xl font-semibold tracking-[var(--tracking-tight)]">{p.role}</div>
            </div>
            <div class="flex items-center gap-6">
              <span class="text-sm text-fg-65">{p.location}</span>
              <span class="hidden lg:inline-flex items-center gap-1.5 text-xs text-fg-mute group-hover:text-fg transition-colors">
                {data.external_label}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-fg-faint group-hover:text-accent group-hover:translate-x-1 group-hover:-translate-y-0.5 transition-all"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
