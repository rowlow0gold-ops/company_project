---
import Layout from "../layouts/Layout.astro";
import { getLang, getServices, getServicesPage } from "../lib/i18n";

const lang = getLang(Astro.url);
const services = getServices(lang);
const page = getServicesPage(lang);
---

<Layout title={page.eyebrow} lang={lang}>
  <section class="pt-40 pb-20 lg:pt-52 lg:pb-28 border-b border-line">
    <div class="container-x grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <div class="lg:col-span-6">
        <div class="text-[11px] uppercase tracking-[0.28em] text-accent mb-6">{page.eyebrow}</div>
        <h1 class="text-[clamp(2.5rem,5vw,4.5rem)] font-semibold leading-[1.05] tracking-[var(--tracking-tighter)] text-balance reveal">
          {page.hero_title}
        </h1>
        <p class="mt-8 text-lg text-fg-70 leading-relaxed reveal" style="transition-delay:120ms">
          {page.hero_body}
        </p>
      </div>
      <div class="lg:col-span-6 reveal" style="transition-delay:200ms">
        <div class="aspect-[5/4] overflow-hidden rounded-2xl border border-line">
          <img src="https://images.pexels.com/photos/3184325/pexels-photo-3184325.jpeg?auto=compress&cs=tinysrgb&w=1400" alt={page.eyebrow} class="w-full h-full object-cover" loading="eager" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="container-x space-y-px bg-line border border-line" data-reveal-children>
      {services.services.map((svc) => (
        <article id={svc.id} class="bg-ink p-10 lg:p-16 grid grid-cols-1 lg:grid-cols-12 gap-8">
          <div class="lg:col-span-4">
            <div class="text-[11px] uppercase tracking-[0.22em] text-fg-mute mb-4">{svc.label}</div>
            <h2 class="text-3xl lg:text-5xl font-semibold tracking-[var(--tracking-tighter)] leading-[1.05]">
              {svc.title}
            </h2>
          </div>
          <div class="lg:col-span-8">
            <p class="text-lg text-fg-soft leading-[1.8] text-pretty">{svc.summary}</p>
            <div class="mt-8 flex flex-wrap gap-2">
              {svc.tags.map((tag) => (
                <span class="text-xs px-3 py-1.5 rounded-full border border-line-strong text-fg-soft">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
