---
import Layout from "../layouts/Layout.astro";
import {
  getLang,
  getHome,
  getServices,
  getNews,
  localizePath,
  t,
} from "../lib/i18n";

const lang = getLang(Astro.url);
const home = getHome(lang);
const services = getServices(lang);
const news = getNews(lang);

const latestNews = news.items.slice(0, 3);

const formatDate = (iso: string) => {
  const d = new Date(iso);
  return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, "0")}.${String(d.getDate()).padStart(2, "0")}`;
};
---

<Layout transparentHeader={true} lang={lang}>
  <!-- HERO -->
  <section class="relative min-h-screen flex items-end overflow-hidden grain hero-section" style="isolation: isolate;">
    <div class="absolute inset-0 z-0 hero-aperture">
      <!-- Hero is always cinematic-dark regardless of site theme. -->
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0A0E1A 0%, #0E1530 45%, #1B2566 100%);"></div>

      <div
        class="absolute inset-0"
        data-hero-rotator
        data-interval={(home.hero as any).bgVideoIntervalMs ?? 9000}
      >
        {((home.hero as any).bgVideos ?? (home.hero.video ? [home.hero.video] : [])).map((url: string, i: number) => (
          <video
            data-hero-video={i}
            autoplay={i === 0}
            muted
            playsinline
            preload={i === 0 ? "auto" : "none"}
            class:list={[
              "absolute inset-0 w-full h-full object-cover transition-opacity duration-1000",
              i === 0 ? "opacity-100" : "opacity-0",
            ]}
          >
            <source src={url} type="video/mp4" />
          </video>
        ))}
      </div>

      <!-- Dark scrim: locked dark so white hero text is always legible. -->
      <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,14,26,0.95) 0%, rgba(10,14,26,0.15) 45%, rgba(10,14,26,0.55) 100%);"></div>
      <div
        class="absolute -top-40 right-[-10%] w-[60rem] h-[60rem] rounded-full"
        style="background: radial-gradient(closest-side, rgba(79,124,255,0.22), transparent 70%);"
      ></div>
    </div>

    <div class="container-x relative z-10 pb-24 pt-32 lg:pt-40 lg:pb-32 w-full">
      <div class="hero-aperture">
        <div class="flex items-center gap-3 text-[11px] uppercase tracking-[0.28em] text-fg-70 mb-8">
          <span class="w-8 h-px bg-fg-faint"></span>
          {home.hero.eyebrow}
        </div>

        <h1 class="text-[clamp(2.5rem,7vw,6.5rem)] font-semibold leading-[1.02] tracking-[var(--tracking-tighter)] max-w-[18ch] text-balance whitespace-pre-line">
          {lang === "en" ? home.hero.title_en : home.hero.title_ko}
        </h1>

        <p class="mt-10 max-w-2xl text-lg lg:text-xl text-fg-soft leading-relaxed text-pretty">
          {home.hero.subtitle}
        </p>

        <div class="mt-12 flex flex-wrap items-center gap-4">
          <a
            href={localizePath(home.hero.cta_link.replace(/^\/en/, ""), lang)}
            class="group inline-flex items-center gap-3 px-7 py-4 rounded-full btn-primary font-medium"
          >
            {home.hero.cta_label}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="transition-transform group-hover:translate-x-1">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href={localizePath("/contact", lang)}
            class="inline-flex items-center gap-3 px-7 py-4 rounded-full border border-line-strong text-fg hover:border-fg transition-colors"
          >
            {t(lang, "cta_primary_secondary")}
          </a>
        </div>
      </div>
    </div>

    <div class="reveal absolute bottom-8 left-1/2 -translate-x-1/2 text-[10px] uppercase tracking-[0.3em] text-fg-mute flex flex-col items-center gap-2" style="transition-delay: 1100ms;">
      <span>{t(lang, "scroll_cue")}</span>
      <span class="w-px h-10 bg-fg-faint"></span>
    </div>
  </section>

  <!-- INTRO -->
  <section class="py-32 lg:py-44">
    <div class="container-x grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-4 reveal">
        <div class="text-[11px] uppercase tracking-[0.28em] text-accent mb-4">
          {home.intro.label}
        </div>
      </div>
      <div class="lg:col-span-8" data-reveal-children>
        <h2 class="text-[clamp(2rem,5vw,4rem)] font-semibold leading-[1.08] tracking-[var(--tracking-tighter)] whitespace-pre-line text-balance">
          {home.intro.title}
        </h2>
        <p class="mt-10 text-lg text-fg-70 leading-[1.75] max-w-2xl text-pretty">
          {home.intro.body}
        </p>
        <a
          href={localizePath("/about", lang)}
          class="mt-10 inline-flex items-center gap-2 text-sm text-fg hover:text-accent transition-colors"
        >
          {t(lang, "learn_more")}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="py-24 lg:py-32 border-t border-line">
    <div class="container-x">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16 lg:mb-20 reveal">
        <div>
          <div class="text-[11px] uppercase tracking-[0.28em] text-accent mb-4">
            {t(lang, "services_section_eyebrow")}
          </div>
          <h2 class="text-[clamp(2rem,4.5vw,3.5rem)] font-semibold leading-[1.08] tracking-[var(--tracking-tighter)] max-w-3xl whitespace-pre-line">
            {t(lang, "services_section_title")}
          </h2>
        </div>
        <a
          href={localizePath("/services", lang)}
          class="inline-flex items-center gap-2 text-sm text-fg-soft hover:text-fg transition-colors"
        >
          {t(lang, "services_section_cta")}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8" data-reveal-children>
        {services.services.map((svc) => (
          <a
            href={localizePath(`/services/${svc.id}`, lang)}
            class="service-card group relative block rounded-2xl overflow-hidden bg-ink-soft border border-line"
          >
            <div class="aspect-[16/10] overflow-hidden">
              {(svc as any).image && (
                <img
                  src={(svc as any).image}
                  alt={svc.title}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-[rgba(10,14,26,0.9)] via-[rgba(10,14,26,0.35)] to-transparent"></div>
            </div>
            <div class="absolute inset-x-0 bottom-0 p-7 lg:p-9 flex flex-col gap-3 text-white">
              <div class="flex items-start justify-between">
                <span class="text-[11px] uppercase tracking-[0.22em] text-white/65">{svc.label}</span>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="text-white/50 group-hover:text-white group-hover:translate-x-1 group-hover:-translate-y-1 transition-all">
                  <path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3 class="text-2xl lg:text-3xl font-semibold tracking-[var(--tracking-tight)]">{svc.title}</h3>
              <p class="text-sm text-white/80 leading-relaxed line-clamp-2 max-w-md">{svc.summary}</p>
              <div class="flex flex-wrap gap-2 pt-2">
                {svc.tags.slice(0, 4).map((tag) => (
                  <span class="text-[11px] px-2.5 py-1 rounded-full border border-white/25 text-white/85">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- NEWS -->
  <section class="py-24 lg:py-32 border-t border-line">
    <div class="container-x">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16 reveal">
        <div>
          <div class="text-[11px] uppercase tracking-[0.28em] text-accent mb-4">
            {t(lang, "news_section_eyebrow")}
          </div>
          <h2 class="text-[clamp(2rem,4.5vw,3.5rem)] font-semibold leading-[1.08] tracking-[var(--tracking-tighter)]">
            {t(lang, "news_section_title")}
          </h2>
        </div>
        <a
          href={localizePath("/news", lang)}
          class="inline-flex items-center gap-2 text-sm text-fg-soft hover:text-fg transition-colors"
        >
          {t(lang, "news_section_cta")}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" data-reveal-children>
        {latestNews.map((n) => (
          <a
            href={n.link}
            class="group block rounded-2xl overflow-hidden border border-line bg-ink-soft hover:bg-ink transition-colors"
          >
            {(n as any).image && (
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={(n as any).image}
                  alt={n.title}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
              </div>
            )}
            <div class="p-7 lg:p-8 flex flex-col gap-4 min-h-[16rem]">
              <div class="flex items-center gap-3 text-[11px] uppercase tracking-[0.22em]">
                <span class="text-accent">{n.category_label}</span>
                <span class="text-fg-mute">{formatDate(n.date)}</span>
              </div>
              <h3 class="text-lg lg:text-xl font-semibold leading-[1.3] tracking-[var(--tracking-tight)] text-balance">
                {n.title}
              </h3>
              <p class="text-sm text-fg-65 leading-relaxed line-clamp-3 mt-auto">{n.excerpt}</p>
              <span class="inline-flex items-center gap-2 text-xs text-fg-70 group-hover:text-accent transition-colors">
                {t(lang, "read_more")}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="py-32 lg:py-40 relative overflow-hidden">
    <div class="absolute inset-0 -z-10 opacity-60" style="background: radial-gradient(ellipse at 50% 0%, var(--color-accent-glow), transparent 60%);"></div>
    <div class="container-x text-center" data-reveal-children>
      <h2 class="text-[clamp(2.25rem,5vw,4.5rem)] font-semibold leading-[1.05] tracking-[var(--tracking-tighter)] text-balance max-w-3xl mx-auto">
        {home.cta.title}
      </h2>
      <p class="mt-8 text-lg text-fg-65 max-w-xl mx-auto text-pretty">{home.cta.subtitle}</p>
      <a
        href={localizePath(home.cta.link.replace(/^\/en/, ""), lang)}
        class="mt-12 inline-flex items-center gap-3 px-8 py-4 rounded-full btn-primary font-medium"
      >
        {home.cta.label}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>
